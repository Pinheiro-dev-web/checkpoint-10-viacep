@model CadastroAlunos.Models.Endereco

@{
    ViewData["Title"] = "Dados Recebidos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">✅ Dados Recebidos com Sucesso (Somente Leitura)</h4>
                </div>
                <div class="card-body p-4">
                    <p class="fs-5">Estes foram os dados processados via <strong>Model Binding</strong> no servidor:</p>
                    <hr />
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>CEP:</strong> @Model.Cep</li>
                        <li class="list-group-item"><strong>Logradouro:</strong> @Model.Logradouro</li>
                        <li class="list-group-item"><strong>Bairro:</strong> @Model.Bairro</li>
                        <li class="list-group-item"><strong>Cidade:</strong> @Model.Cidade</li>
                        <li class="list-group-item"><strong>Estado (UF):</strong> @Model.Estado</li>
                    </ul>
                    <a asp-action="Index" class="btn btn-primary w-100 mt-4">Realizar Nova Consulta</a>
                </div>
            </div>
        </div>
    </div>
</div>
